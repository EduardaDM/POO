public class Teste {

    public Teste() {
        try {
            Pessoa p1 = new Pessoa();
            //Pessoa p = new Pessoa(""); //--> gera a exceção.
            Pessoa p2 = new Pessoa("Luciana");
            Pessoa p3 = new Pessoa("Luciana", "Kohler");

            JOptionPane.showMessageDialog(null, p1.getNome() + " " + p1.getSobrenome());
            JOptionPane.showMessageDialog(null, p2.getNome() + " " + p2.getSobrenome());
