            lista += p3.getNome() + " " + p3.getSobrenome();
            
            JOptionPane.showMessageDialog(null, lista);
        } catch (IllegalArgumentException e) {
            JOptionPane.showMessageDialog(null, e.getMessage());
        }
    }

    public static void main(String[] args) {
