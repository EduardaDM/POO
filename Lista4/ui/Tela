    private void jbtnCalcularActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_jbtnCalcularActionPerformed
        try {
            int altura = Integer.parseInt(jtfAltura.getText());
            int comprimento = Integer.parseInt(jtfComprimento.getText());

            Retangulo retangulo = new Retangulo(altura, comprimento);

            jlbArea.setText(String.valueOf(retangulo.calcularArea()));
            jlbPerimetro.setText(String.valueOf(retangulo.calcularPerimetro()));
        } catch (IllegalArgumentException e) {
            JOptionPane.showMessageDialog(null, e.getMessage());
            jbtLimparActionPerformed(evt);
        }
    }//GEN-LAST:event_jbtnCalcularActionPerformed

