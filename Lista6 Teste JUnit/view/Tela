    /**
     * Botão que calcula o IRPF e apresenta o imposto a pagar e a faixa
     * 
     * @param evt clique do botão
     */
    private void jbtnCalcularActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_jbtnCalcularActionPerformed
        // TODO add your handling code here:
        String nome = jtfFuncionario.getText();
        String salario = jtfSalario.getText();
            
        if (nome.trim().equals("")) {
            JOptionPane.showMessageDialog(this, "Nome deve ser preenchido");
        }
        if (salario.trim().equals("")) {
            JOptionPane.showMessageDialog(this, "Salário deve ser preenchido");
        }  
        
        Funcionario f = new Funcionario(nome, Double.parseDouble(salario));

        double imposto = f.calcularIrpf();
        FaixaIrpf faixa = f.identificarFaixaIrpf();

        DecimalFormat df = new DecimalFormat("0.00");
        jlbImposto.setText(df.format(imposto));

        String faixaS = "";
        switch (faixa) {
            case PRIMEIRA:
                faixaS = "1ª faixa";
                break;
            case SEGUNDA:
                faixaS = "2ª faixa";
                break;
            case TERCEIRA:
                faixaS = "3ª faixa";
                break;
            case QUARTA:
                faixaS = "4ª faixa";
                break;
            default:
                faixaS = "5ª faixa";
        }
                jlbFaixa.setText("O salário está na " + faixaS);
    }//GEN-LAST:event_jbtnCalcularActionPerformed

